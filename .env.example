.env.example
# ============================================
# MEDICAL RESEARCH ASSISTANT - ENVIRONMENT
# ============================================

# Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Cloud Deployment URLs (For production)
# FRONTEND_URL=https://your-app.vercel.app
# API_URL=https://your-api.railway.app

# ============================================
# DATABASE & CACHE
# ============================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=medical_research_assistant

# Redis (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# EXTERNAL APIs
# ============================================

# PubMed API (free, requires key for higher rate limit)
PUBMED_API_KEY=your_pubmed_api_key_here

# OpenAlex (free, no key required)
OPENALEX_EMAIL=your_email@example.com

# ClinicalTrials.gov (free, no key required)
# No configuration needed

# ============================================
# LLM SERVICE - Groq API
# ============================================

# Groq API Key (Get free key at https://console.groq.com)
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# ============================================
# LOGGING & MONITORING
# ============================================

LOG_LEVEL=debug
SENTRY_DSN=

# ============================================
# SECURITY
# ============================================

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# FEATURES (Feature flags)
# ============================================

ENABLE_PERSONALIZATION=true
ENABLE_HALLUCINATION_DETECTION=true
ENABLE_CACHING=true
ENABLE_STREAMING_RESPONSES=true
ENABLE_COLLABORATIVE_FILTERING=false

# ============================================
# ANALYTICS
# ============================================

ENABLE_ANALYTICS=true
ANALYTICS_PROVIDER=google  # google | mixpanel | internal
ANALYTICS_KEY=

# ============================================
# DEPLOYMENT (Production only)
# ============================================

# Docker / Kubernetes
DEPLOYMENT_ENV=local  # local | staging | production
POD_NAME=
POD_NAMESPACE=

# Secrets management
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_ENABLED=false
